# ==========================================
# M4Chat2 Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# or set these variables in Portainer Environment section

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=workspace_db

# Full database connection URL (used by API server)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/workspace_db

# ==========================================
# API Server Configuration
# ==========================================
# Port for API server (inside container)
PORT=8080

# Node environment
NODE_ENV=production

# ==========================================
# Frontend Configuration
# ==========================================
# Base path for frontend (usually / for root deployment)
BASE_PATH=/

# ==========================================
# Optional: Docker Compose Port Mapping
# ==========================================
# External port for web service (change if 80 is taken)
WEB_PORT=80
